# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get these values from: Supabase Dashboard > Project Settings > API

# Public URL (both client and server)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
SUPABASE_URL=your_supabase_project_url

# Keys
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# VERCEL API ENDPOINTS
# ===========================================
# After deploying to Vercel, update these URLs with your project URL
# Example: https://autrex.vercel.app or your custom domain

VITE_VERSION_CHECK_API=https://your-project.vercel.app/api/version/check
VITE_LICENSE_ACTIVATE_API=https://your-project.vercel.app/api/licenses/activate
VITE_LICENSE_VALIDATE_API=https://your-project.vercel.app/api/licenses/validate

# Legacy (backward compatibility)
LICENSE_API_URL=https://your-project.vercel.app
